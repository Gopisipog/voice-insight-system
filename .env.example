# --- API Keys ---
# OpenAI (required for Whisper audio transcription - DeepSeek does NOT have audio transcription)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek (for AI-powered text analysis - much cheaper than OpenAI GPT)
# Get yours at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Transcription Configuration
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_INPUT_DEVICE_ID=  # Set to Stereo Mix device ID for desktop audio capture

# Analysis Commands
FILTER_COMMAND=powershell -Command "$input | findstr /i 'gap'"
